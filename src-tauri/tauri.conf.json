{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyAgentPilot",
  "version": "1.4.2",
  "identifier": "io.github.hyqf.agent",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Easy Agent Pilot",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg", "app", "deb", "appimage"],
    "resources": {
      "../node_modules/.pnpm/playwright-core@1.58.2/node_modules/playwright-core/": "playwright-core/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "hyqf",
    "shortDescription": "Easy Agent Pilot - AI Agent Management Tool",
    "longDescription": "A powerful AI Agent management tool that helps you manage and orchestrate AI agents efficiently.",
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": "-"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "tsp": false,
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDA2MTU5NzIzMDE3Q0U1NTYKUldSVzVYd0JJNWNWQmxUSFNHc1c5ZkJPeUIyeFN6R21zaHRyWHp5dmdwNDZjUTlRbUk2bC9BMGYK",
      "endpoints": [
        "https://github.com/hyqf98/easy-agent-pilot/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
